{%- liquid
  assign loading = "lazy"
  assign decoding = "async"
-%}

<style>
  #shopify-section-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .ms-wholesale {
    background: rgb(var(--color-base-text));
    border-radius: 24px;
    padding: 56px 40px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .ms-wholesale {
      grid-template-columns: 1fr 1fr;
      padding: 72px 64px;
      gap: 64px;
    }
  }

  #shopify-section-{{ section.id }} .ms-wholesale__bg {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .ms-wholesale__title {
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.15;
    color: rgb(var(--color-base-background-1));
    margin: 0 0 16px;
  }

  #shopify-section-{{ section.id }} .ms-wholesale__title em {
    font-style: italic;
    color: rgb(var(--color-button));
  }

  #shopify-section-{{ section.id }} .ms-wholesale__body {
    font-family: var(--font-body-family);
    font-size: 15px;
    line-height: 1.75;
    color: rgb(var(--color-base-background-1) / 0.65);
    margin: 0 0 28px;
  }

  #shopify-section-{{ section.id }} .ms-wholesale__feats {
    list-style: none;
    padding: 0;
    margin: 0 0 36px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .ms-wholesale__feat {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body-family);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-base-background-1) / 0.8);
  }

  #shopify-section-{{ section.id }} .ms-wholesale__feat-icon {
    width: 18px;
    height: 18px;
    min-width: 18px;
    color: rgb(var(--color-button));
  }

  #shopify-section-{{ section.id }} .ms-wholesale__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: rgb(var(--color-base-background-1));
    border: 1.5px solid rgb(var(--color-base-background-1) / 0.4);
    padding: 14px 28px;
    border-radius: 5px;
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .ms-wholesale__btn:hover {
    background: rgb(var(--color-button));
    border-color: rgb(var(--color-button));
    color: rgb(var(--color-button-label));
  }

  #shopify-section-{{ section.id }} .ms-wholesale__btn svg {
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .ms-wholesale__btn:hover svg {
    transform: translateX(3px);
  }

  #shopify-section-{{ section.id }} .ms-wholesale__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    align-items: start;
  }

  #shopify-section-{{ section.id }} .ms-wholesale__card {
    background: rgb(var(--color-base-background-1));
    border-radius: 5px;
    padding: 20px;
  }

  #shopify-section-{{ section.id }} .ms-wholesale__card:nth-child(even) {
    margin-top: 20px;
  }

  #shopify-section-{{ section.id }} .ms-wholesale__card-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgb(var(--color-button) / 0.1);
    color: rgb(var(--color-button));
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }

  #shopify-section-{{ section.id }} .ms-wholesale__card-icon svg {
    width: 18px;
    height: 18px;
  }

  #shopify-section-{{ section.id }} .ms-wholesale__card-title {
    font-family: var(--font-heading-family);
    font-size: 15px;
    font-weight: 700;
    color: rgb(var(--color-base-text));
    margin: 0 0 6px;
  }

  #shopify-section-{{ section.id }} .ms-wholesale__card-desc {
    font-family: var(--font-body-family);
    font-size: 12px;
    line-height: 1.6;
    color: rgb(var(--color-base-text) / 0.6);
    margin: 0;
  }
</style>

<div class="s--margin color-{{ section.settings.color_scheme }} s-container-radius"
     data-ui-component="MS Wholesale"
     role="region"
     aria-labelledby="ms-wholesale-heading-{{ section.id }}">

  <div class="ctnr">
    <div class="ms-wholesale">

      <svg class="ms-wholesale__bg" viewBox="0 0 100 100" preserveAspectRatio="none">
        <defs>
          <pattern id="ms-grid-{{ section.id }}" width="8" height="8" patternUnits="userSpaceOnUse">
            <path d="M 8 0 L 0 0 0 8" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100" height="100" fill="url(#ms-grid-{{ section.id }})"/>
      </svg>

      <div style="position:relative;z-index:2;">
        {%- if section.settings.title != blank -%}
          <h2 class="ms-wholesale__title" id="ms-wholesale-heading-{{ section.id }}">
            {{ section.settings.title }}
            {%- if section.settings.title_accent != blank -%}
              <br/><em>{{ section.settings.title_accent }}</em>
            {%- endif -%}
          </h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <p class="ms-wholesale__body">{{ section.settings.body }}</p>
        {%- endif -%}

        {%- if section.settings.feat_1 != blank or section.settings.feat_2 != blank -%}
          <ul class="ms-wholesale__feats">
            {%- if section.settings.feat_1 != blank -%}
              <li class="ms-wholesale__feat">
                <svg class="ms-wholesale__feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 12H4m8-8l8 8-8 8"/>
                </svg>
                {{ section.settings.feat_1 }}
              </li>
            {%- endif -%}
            {%- if section.settings.feat_2 != blank -%}
              <li class="ms-wholesale__feat">
                <svg class="ms-wholesale__feat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 12H4m8-8l8 8-8 8"/>
                </svg>
                {{ section.settings.feat_2 }}
              </li>
            {%- endif -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.btn_label != blank -%}
          <a class="ms-wholesale__btn" href="{{ section.settings.btn_link | default: '#' }}">
            {{ section.settings.btn_label }}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14m-7-7l7 7-7 7"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

      <div class="ms-wholesale__cards" style="position:relative;z-index:2;">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature_card' -%}
            <div class="ms-wholesale__card" {{ block.shopify_attributes }}>
              <div class="ms-wholesale__card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  {%- case block.settings.icon -%}
                    {%- when 'gear' -%}
                      <path d="M12 15a3 3 0 100-6 3 3 0 000 6z"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
                    {%- when 'document' -%}
                      <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                    {%- when 'pill' -%}
                      <path d="M10.5 20H4a2 2 0 01-2-2V6a2 2 0 012-2h16a2 2 0 012 2v4"/><path d="M15 15l5 5m0-5l-5 5"/>
                    {%- when 'globe' -%}
                      <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
                    {%- when 'box' -%}
                      <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                    {%- else -%}
                      <circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5"/>
                  {%- endcase -%}
                </svg>
              </div>
              {%- if block.settings.title != blank -%}
                <p class="ms-wholesale__card-title">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="ms-wholesale__card-desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "MS Wholesale",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Wholesale"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Title Accent (italic, second line)",
      "default": "Logistics"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body Text",
      "default": "Engineered for high-volume manufacturing. Container-load fulfillment and custom micronization for supplement, pharmaceutical, and industrial clients."
    },
    {
      "type": "header",
      "content": "Feature List"
    },
    {
      "type": "text",
      "id": "feat_1",
      "label": "Feature 1",
      "default": "Palletized & Bulk Bags (1,000kg+)"
    },
    {
      "type": "text",
      "id": "feat_2",
      "label": "Feature 2",
      "default": "International Freight & Customs Support"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Inquire About Bulk Supply"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 56,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "gear",     "label": "Gear" },
            { "value": "document", "label": "Document" },
            { "value": "pill",     "label": "Capsule" },
            { "value": "globe",    "label": "Globe" },
            { "value": "box",      "label": "Box" }
          ],
          "default": "gear"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Custom Grinds"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Card Description",
          "default": "Variable mesh from coarse granular to 325-mesh ultra-fine."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MS Wholesale",
      "blocks": [
        {
          "type": "feature_card",
          "settings": {
            "icon": "gear",
            "title": "Custom Grinds",
            "description": "Variable mesh from coarse granular to 325-mesh ultra-fine."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "icon": "document",
            "title": "Compliance Docs",
            "description": "Full MSDS and specification sheets provided instantly."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "icon": "pill",
            "title": "Capsule Fills",
            "description": "Pre-measured fills for private label supplement programs."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "icon": "globe",
            "title": "Global Shipping",
            "description": "Export-ready documentation for 40+ countries."
          }
        }
      ]
    }
  ]
}
{% endschema %}
