          "id": "collection_list",
          "label": "t:general.settings.collections.label"
        },
        {
          "type": "header",
          "content": "t:general.settings.headers.header_large_screen.content"
        },
        {
          "type": "select",
          "id": "items_per_row_on_desktop",
          "label": "t:general.settings.items_per_row_on_large_screen.label",
          "info": "t:general.settings.items_per_row_on_large_screen.info",
          "options": [
            {
