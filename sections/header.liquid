      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "header_sticky",
      "label": "t:sections.header.settings.sticky_header.label",
      "options": [
        {
          "value": "false",
          "label": "t:sections.header.settings.options.option_none.label"
        },
        {
          "value": "always_reveal",
          "label": "t:sections.header.settings.options.option_always.label"
        },
