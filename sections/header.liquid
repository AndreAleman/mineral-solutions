  "blocks": [
    {
      "type": "collections_menu",
      "name": "t:sections.header.blocks.collections_menu.name",
      "settings": [
        {
          "type": "header",
          "content": "t:general.settings.headers.general.content"
        },
        {
          "type": "text",
          "id": "header_collection_title",
          "label": "t:genaral.settings.menu_item_name.label",
          "info": "t:sections.header.blocks.collections_menu.settings.menu_item_name.info",
