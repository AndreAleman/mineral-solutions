{% doc %}
  @prompt
  the home page section with the 3 clays
    Create a slideshow section with 3 slides. Each slide should have a two-column layout: image on the left side, and on the right side a title, subtitle, description paragraph (with support for line breaks and bullet points), and a button below the description. The description field should support rich text formatting including multiple lines and bullet lists. Include slideshow navigation arrows and dots. Make it responsive so on mobile the image and content stack vertically.
{% enddoc %}
{% assign ai_gen_id = 'typesofclayblock' %}


{% style %}
  .ai-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-slideshow-slides-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} {
    min-width: 100%;
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 60px 40px;
  }

  .ai-slideshow-image-wrapper-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-slideshow-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-slideshow-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-slideshow-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-slideshow-content-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-slideshow-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    margin-top: -8px;
    line-height: 1.2;
  }

  .ai-slideshow-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-slideshow-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    padding-right: 60px;
  }

  .ai-slideshow-description-{{ ai_gen_id }} ul {
    margin: 8px 0;
    padding-left: 20px;
  }

  .ai-slideshow-description-{{ ai_gen_id }} li {
    margin: 4px 0;
  }

  .ai-slideshow-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_size }}px;
    transition: background-color 0.3s ease;
    align-self: flex-start;
  }

  .ai-slideshow-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-slideshow-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_bg_color }};
    color: {{ block.settings.nav_icon_color }};
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background-color 0.3s ease;
  }

  .ai-slideshow-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_bg_color }};
  }

  .ai-slideshow-nav-prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-slideshow-nav-next-{{ ai_gen_id }} {
    right: 20px;
  }

  .ai-slideshow-nav-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-slideshow-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    padding: 20px 0;
  }

  .ai-slideshow-dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-slide-{{ ai_gen_id }} {
      flex-direction: column;
      padding: 40px 20px;
      gap: 24px;
    }

    .ai-slideshow-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-slideshow-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }

    .ai-slideshow-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }

    .ai-slideshow-nav-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-slideshow-nav-prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-slideshow-nav-next-{{ ai_gen_id }} {
      right: 10px;
    }
  }
{% endstyle %}

<slideshow-component-{{ ai_gen_id }} class="ai-slideshow-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-slideshow-container-{{ ai_gen_id }}">
    <div class="ai-slideshow-slides-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'slide_' | append: i | append: '_image'
          assign title_key = 'slide_' | append: i | append: '_title'
          assign subtitle_key = 'slide_' | append: i | append: '_subtitle'
          assign description_key = 'slide_' | append: i | append: '_description'
          assign button_text_key = 'slide_' | append: i | append: '_button_text'
          assign button_link_key = 'slide_' | append: i | append: '_button_link'

          assign slide_image = block.settings[image_key]
          assign slide_title = block.settings[title_key]
          assign slide_subtitle = block.settings[subtitle_key]
          assign slide_description = block.settings[description_key]
          assign slide_button_text = block.settings[button_text_key]
          assign slide_button_link = block.settings[button_link_key]
        %}

        <div class="ai-slideshow-slide-{{ ai_gen_id }}" data-slide="{{ i }}">
          <div class="ai-slideshow-image-wrapper-{{ ai_gen_id }}">
            {% if slide_image %}
              <img
                src="{{ slide_image | image_url: width: 1200 }}"
                alt="{{ slide_image.alt | escape }}"
                loading="lazy"
                width="{{ slide_image.width }}"
                height="{{ slide_image.height }}"
                class="ai-slideshow-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-slideshow-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-slideshow-content-{{ ai_gen_id }}">
            {% if slide_subtitle != blank %}
              <p class="ai-slideshow-subtitle-{{ ai_gen_id }}">{{ slide_subtitle }}</p>
            {% endif %}

            {% if slide_title != blank %}
              <h2 class="ai-slideshow-title-{{ ai_gen_id }}">{{ slide_title }}</h2>
            {% endif %}



            {% if slide_description != blank %}
              <div class="ai-slideshow-description-{{ ai_gen_id }}">
                {{ slide_description }}
              </div>
            {% endif %}

            {% if slide_button_text != blank %}
              <a
                href="{{ slide_button_link | default: '#' }}"
                class="ai-slideshow-button-{{ ai_gen_id }}"
              >
                {{ slide_button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <button
      class="ai-slideshow-nav-{{ ai_gen_id }} ai-slideshow-nav-prev-{{ ai_gen_id }}"
      aria-label="Previous slide"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <button
      class="ai-slideshow-nav-{{ ai_gen_id }} ai-slideshow-nav-next-{{ ai_gen_id }}"
      aria-label="Next slide"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>

  <div class="ai-slideshow-dots-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      <button
        class="ai-slideshow-dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
        data-slide="{{ i }}"
        aria-label="Go to slide {{ i }}"
      ></button>
    {% endfor %}
  </div>
</slideshow-component-{{ ai_gen_id }}>

<script>
  (function() {
    class SlideshowComponent{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 1;
        this.totalSlides = 3;
      }

      connectedCallback() {
        this.slidesContainer = this.querySelector('.ai-slideshow-slides-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-slideshow-nav-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-slideshow-nav-next-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-slideshow-dot-{{ ai_gen_id }}');

        this.prevButton.addEventListener('click', () => this.previousSlide());
        this.nextButton.addEventListener('click', () => this.nextSlide());

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const slideNumber = parseInt(e.target.dataset.slide);
            this.goToSlide(slideNumber);
          });
        });

        this.startAutoplay();
      }

      goToSlide(slideNumber) {
        this.currentSlide = slideNumber;
        const offset = (slideNumber - 1) * -100;
        this.slidesContainer.style.transform = `translateX(${offset}%)`;
        this.updateDots();
      }

      nextSlide() {
        this.currentSlide = this.currentSlide >= this.totalSlides ? 1 : this.currentSlide + 1;
        this.goToSlide(this.currentSlide);
        this.resetAutoplay();
      }

      previousSlide() {
        this.currentSlide = this.currentSlide <= 1 ? this.totalSlides : this.currentSlide - 1;
        this.goToSlide(this.currentSlide);
        this.resetAutoplay();
      }

      updateDots() {
        this.dots.forEach((dot, index) => {
          if (index + 1 === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, 5000);
      }

      resetAutoplay() {
        clearInterval(this.autoplayInterval);
        this.startAutoplay();
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('slideshow-component-{{ ai_gen_id }}', SlideshowComponent{{ ai_gen_id }});
  })();
</script>

