{% doc %}
  @prompt
    Create a product showcase section with 4 customizable blocks. Each block should display a product image, product name, and description text. The section should have a clean, professional layout that works well for highlighting main product categories. Include settings to customize the image, heading text, and description for each of the 4 product types. Make it responsive and visually balanced.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-showcase-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
  }

  .ai-product-showcase__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-product-showcase__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-product-showcase__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-product-showcase__item-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .ai-product-showcase__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-product-showcase__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-showcase__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-showcase__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-showcase__content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }

  .ai-product-showcase__heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    line-height: 1.3;
  }

  .ai-product-showcase__description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
  }

  @media screen and (max-width: 989px) {
    .ai-product-showcase__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-showcase-{{ ai_gen_id }} {
      padding: 30px 15px;
    }

    .ai-product-showcase__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.6 }}px;
    }

    .ai-product-showcase__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.9 }}px;
    }

    .ai-product-showcase__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<product-showcase-{{ ai_gen_id }} class="ai-product-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-showcase__container-{{ ai_gen_id }}">
    <div class="ai-product-showcase__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'product_' | append: i | append: '_image'
          assign heading_key = 'product_' | append: i | append: '_heading'
          assign description_key = 'product_' | append: i | append: '_description'
          
          assign product_image = block.settings[image_key]
          assign product_heading = block.settings[heading_key]
          assign product_description = block.settings[description_key]
        %}
        
        <div class="ai-product-showcase__item-{{ ai_gen_id }}">
          <div class="ai-product-showcase__image-wrapper-{{ ai_gen_id }}">
            {% if product_image %}
              <img
                src="{{ product_image | image_url: width: 800 }}"
                alt="{{ product_image.alt | escape }}"
                loading="lazy"
                width="800"
                height="800"
                class="ai-product-showcase__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-product-showcase__placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          <div class="ai-product-showcase__content-{{ ai_gen_id }}">
            {% if product_heading != blank %}
              <h3 class="ai-product-showcase__heading-{{ ai_gen_id }}">
                {{ product_heading }}
              </h3>
            {% endif %}
            
            {% if product_description != blank %}
              <div class="ai-product-showcase__description-{{ ai_gen_id }}">
                {{ product_description }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</product-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-product-showcase__item-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.items.forEach((item) => {
          item.setAttribute('role', 'article');
        });
      }
    }

    customElements.define('product-showcase-{{ ai_gen_id }}', ProductShowcase{{ ai_gen_id }});
  })();
</script>

