{%- for value in option.values -%}
  {%- liquid
    assign option_disabled = true
    if value.available
      assign option_disabled = false
    endif

    assign swatch_value = null
    if value.swatch.color != blank or value.swatch.image != blank
      if value.swatch.image
        assign swatch_value = value.swatch.image | image_url
      elsif value.swatch.color
        assign swatch_value = value.swatch.color
      else
        assign swatch_value = null
      endif
    endif
  -%}

  <div class="product-swatches__item js-variant-option-value product-option__value {% if option_disabled %}product-option--unavailable{% endif %}" data-value="{{ value | escape }}-{{ index }}">
    <input type="radio" aria-label="{{ option.name }}" class="input--variant form__control js-variant-item {{ input_class | default: 'js-variant-radio-item' }} visually-hidden"
      id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
      data-name="{{ option.name }}"
      value="{{ value | escape }}"
      data-variant-value="{{ value | escape }}-{{ index }}"
      {% if option.selected_value == value %}checked{% endif %}
      data-option-value-id="{{ value.id }}"
      >
    <label class="form__label form__label--{{- settings.swatch_source }} d-block" for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" tabindex="-1">
      <span class="product-swatches product-swatches--{{- settings.swatch_source }} product-variant-label o-hidden js-variant-swatch-item d-block br-50p subtext p-relative c-pointer o-hidden d-flex center-xs middle-xs ta-center" aria-hidden="true" data-option-value="{{ value | downcase | escape | remove: " " }}" data-swatch-source="{{ settings.swatch_source }}" data-swatch-option-value="{{ swatch_value }}">
        {% if settings.swatch_source == 'variant_image' %}
          {%- liquid
              assign selected_variant = product.selected_variant
              for variant in product.variants
                if variant.title contains value and variant.image
                  assign selected_variant = variant
                  break
                endif
              endfor
            -%}
          {%- if selected_variant.image -%}
            {{ selected_variant.image | image_url: width: 200 | image_tag: widths: '200', class: 'product-swatches-image absolute zi-1 top-0 left-0 w-100 h-100 of-cover', loading: "lazy" , fetchpriority: "auto", decoding: "async" }}
          {%- endif -%}
        {% endif %}
        <span class="variant-option-label js-variant-option-label pe-none p-absolute">{{ value }}</span>
      </span>
    </label>
  </div>
{%- endfor -%}