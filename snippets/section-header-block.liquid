{% liquid
  assign content_align_class_desktop = 'top-md ta-left-md start-md'
  if content_align_desktop contains 'ta-center'
    assign content_align_class_desktop = 'middle-md ta-center-md center-md'
  endif

  assign content_align_class_mobile = 'top-xs ta-left start-xs'
  if content_align_mobile contains 'ta-center'
    assign content_align_class_mobile = 'middle-xs ta-center center-xs'
  endif

  case settings.highlighted_heading_style
    when 'highlighted_font'
      assign highlighted_first_dom = '<span class="prominent-heading">'
      assign highlighted_last_dom = '</span>'
    when 'highlighted_color'
      unless settings.highlighted_color == blank or settings.highlighted_color.alpha == 0
        assign highlighted_first_dom = '<span style="color: ' | append: settings.highlighted_color | append: ';">'
        assign highlighted_last_dom = '</span>'
      endunless
    when 'highlighted_underline'
      assign highlighted_first_dom = '<span class="d-inline-block p-relative highlighted-word">'
      assign highlighted_last_dom = '</span>'
      assign highlighted_underline_color = 'var(--color-normal-text)'
      unless settings.highlighted_underline_color == blank or settings.highlighted_underline_color.alpha == 0
        assign highlighted_underline_color = settings.highlighted_underline_color
      endunless
  endcase
  assign has_button = false
%}

<div class="s-header {{ header_class }}">
  <div class="s-header__content s-header__banner d-flex fd-column {{ content_align_class_mobile }} {{ content_align_class_desktop }} wb-break-word" >
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'subheading' -%}
          <div class="s-header__sub s-header__item hide-empty d-block {{ settings.subheading_style }}" style="--duration: .6s;" {{ block.shopify_attributes }}>{{- block.settings.subheading | escape -}}</div>
        {%- when 'heading' -%}
          <sht-split-line class="d-inline-block" {% if settings.highlighted_heading_style == 'highlighted_underline' %}data-highlighted-underline-style="{{- settings.highlighted_underline_style -}}" data-highlighted-underline-thickness="{{- settings.highlighted_underline_thickness -}}" data-highlighted-underline-color="{{- highlighted_underline_color -}}"{% endif %} {{ block.shopify_attributes }}>
            <h2 id="sectionHeading-{{ section.id | md5 | truncate: 12, '' }}" class="s-header__title {{ block.settings.heading_size }} wb-break-word hide-empty d-block" style="--duration: .6s; --delay: .3s">
              {{- block.settings.heading | replace: '[', highlighted_first_dom | replace: ']', highlighted_last_dom -}}
            </h2>
          </sht-split-line>
        {%- when 'description' -%}
          <div class="s-header__desc s-header__item rte hide-empty" {{ block.shopify_attributes }}>{{- block.settings.description -}}</div>
        {%- when 'button' -%}
          <div class="s-header__buttons s-header__item d-flex gap-12 fw-wrap hide-empty {{ content_align_class_mobile }} {{ content_align_class_desktop }}" {{ block.shopify_attributes }}>
            {%- if block.settings.button_main_text != blank -%}
              <a class="btn btn--large {{ block.settings.button_main_style }}" href="{{- block.settings.button_main_link | default: '#' -}}" {% if block.settings.button_main_link == blank %} tabindex="-1" {% endif %}>{{- block.settings.button_main_text -}}</a>
            {%- endif -%}
            {%- if block.settings.button_sub_text != blank -%}
              <a class="btn btn--large {{ block.settings.button_sub_style }}" href="{{- block.settings.button_sub_link | default: '#' -}}" {% if block.settings.button_sub_link == blank %} tabindex="-1" {% endif %}>{{- block.settings.button_sub_text -}}</a>
            {%- endif -%}
          </div>
        {%- when 'countdown'-%}
          {% render 'countdown', block: block %}
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>